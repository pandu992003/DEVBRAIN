# DevBrain Environment Configuration
# Copy this to .env and fill in your values

# Application
APP_ENV=development
DEBUG=True
SECRET_KEY=change-me-in-production-super-secret-key-min-32-chars

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./devbrain.db

# GitHub OAuth (for GitHub data source integration)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI / OpenRouter (for AI-powered recommendations)
OPENROUTER_API_KEY=
AI_MODEL=google/gemma-3-4b-it

# AWS / Snowflake Landing Zone
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=devbrain-raw-events
